# ARES Voice App — Configuración

# Backend
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ARES API (LLM)
ARES_SESSION_ID=ARES-APP
ARES_API_URL=http://localhost:8000
ARES_API_KEY=***
ARES_MODEL=openclaw/main

# TTS (Edge TTS)
TTS_VOICE=es-ES-AlvaroNeural
TTS_LANG=es
TTS_RATE=+5%
TTS_PITCH=-2Hz
TTS_VOLUME=+0%